# Canton JSON Ledger API
LEDGER_API_URL=http://localhost:3975

# Keycloak OAuth2 (backend service account)
KEYCLOAK_URL=http://keycloak.localhost:8082
KEYCLOAK_REALM=AppProvider
KEYCLOAK_CLIENT_ID=app-provider-validator
KEYCLOAK_CLIENT_SECRET=your-client-secret-here

# Backend server
BACKEND_PORT=4000

# Default parties (set after party allocation)
VENDOR_PARTY=app-provider::1220abcd...
CUSTOMER_PARTY=app-user::1220efgh...

# Frontend (Vite uses VITE_ prefix)
VITE_BACKEND_URL=http://localhost:4000
VITE_LEDGER_API_URL=http://localhost:3975
